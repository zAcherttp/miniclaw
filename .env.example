# Miniclaw Environment Configuration Template

# --- Telegram Integration ---
# Your Telegram Bot Token, obtain this from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# --- Ollama Configuration ---
# The URL of your local or custom Ollama API deployment
OLLAMA_API_URL=http://127.0.0.1:11434
# Optional: API key for Ollama deployments that require authentication
OLLAMA_API_KEY=

# --- OpenAI Configuration ---
# Your OpenAI API Key (or key for compatible endpoints)
OPENAI_API_KEY=
# Optional: Custom baseURL for proxies, gateways, or OpenRouter
OPENAI_API_BASE=

# --- Google GenAI Configuration ---
# Your Google Gemini API Key
GOOGLE_API_KEY=
